<odoo>

<record id="school_enrollment_ou" model="ir.rule">
    <field name="name">school_enrollment - Responsible to operating unit data</field>
    <field name="model_id" ref="ssi_school.model_school_enrollment" />
    <field name="groups" eval="[(4, ref('school_enrollment_operating_unit_group'))]" />
    <field
            name="domain_force"
        >[('operating_unit_id','in',[g.id for g in user.operating_unit_ids])]</field>
    <field name="perm_unlink" eval="1" />
    <field name="perm_write" eval="1" />
    <field name="perm_read" eval="1" />
    <field name="perm_create" eval="1" />
</record>

</odoo>

<odoo>

<record id="school_teacher_view_tree_ou" model="ir.ui.view">
    <field name="name">school_teacher tree - operating unit</field>
    <field name="model">school_teacher</field>
    <field name="inherit_id" ref="ssi_school.school_teacher_view_tree" />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='name']" position="after">
                <field
                        name="operating_unit_ids"
                        widget="many2many_tags"
                        groups="operating_unit.group_multi_operating_unit"
                        optional="hide"
                    />
            </xpath>
        </data>
    </field>
</record>

<record id="school_teacher_view_form_ou" model="ir.ui.view">
    <field name="name">school_teacher form - operating unit</field>
    <field name="model">school_teacher</field>
    <field name="inherit_id" ref="ssi_school.school_teacher_view_form" />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='active']" position="after">
                <field
                        name="operating_unit_ids"
                        widget="many2many_tags"
                        groups="operating_unit.group_multi_operating_unit"
                    />
            </xpath>
        </data>
    </field>
</record>

</odoo>

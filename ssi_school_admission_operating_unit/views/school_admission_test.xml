<odoo>

<record id="school_admission_test_view_tree_ou" model="ir.ui.view">
    <field name="name">school_admission_test tree - operating unit</field>
    <field name="model">school_admission_test</field>
    <field
            name="inherit_id"
            ref="ssi_school_admission.school_admission_test_view_tree"
        />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='company_id']" position="after">
                <field
                        name="operating_unit_id"
                        groups="operating_unit.group_multi_operating_unit"
                        optional="hide"
                    />
            </xpath>
        </data>
    </field>
</record>

<record id="school_admission_test_view_form_ou" model="ir.ui.view">
    <field name="name">school_admission_test form - operating unit</field>
    <field name="model">school_admission_test</field>
    <field
            name="inherit_id"
            ref="ssi_school_admission.school_admission_test_view_form"
        />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='company_id']" position="after">
                <field
                        name="operating_unit_id"
                        groups="operating_unit.group_multi_operating_unit"
                    />
            </xpath>
        </data>
    </field>
</record>

<record id="school_admission_test_view_search_ou" model="ir.ui.view">
    <field name="name">school_admission_test search - operating unit</field>
    <field name="model">school_admission_test</field>
    <field
            name="inherit_id"
            ref="ssi_school_admission.school_admission_test_view_search"
        />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//group[@name='group_by']" position="inside">
                <filter
                        name="grp_ou"
                        string="Operating Unit"
                        context="{'group_by':'operating_unit_id'}"
                        groups="operating_unit.group_multi_operating_unit"
                    />
            </xpath>
        </data>
    </field>
</record>

</odoo>

<odoo>

<record id="school_admission_form_ou" model="ir.rule">
    <field
            name="name"
        >school_admission_form - Responsible to operating unit data</field>
    <field name="model_id" ref="ssi_school_admission.model_school_admission_form" />
    <field
            name="groups"
            eval="[(4, ref('school_admission_form_operating_unit_group'))]"
        />
    <field
            name="domain_force"
        >[('operating_unit_id','in',[g.id for g in user.operating_unit_ids])]</field>
    <field name="perm_unlink" eval="1" />
    <field name="perm_write" eval="1" />
    <field name="perm_read" eval="1" />
    <field name="perm_create" eval="1" />
</record>

</odoo>

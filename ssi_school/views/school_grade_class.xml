<odoo>
<record id="school_grade_class_view_search" model="ir.ui.view">
    <field name="name">school_grade_class - search</field>
    <field name="model">school_grade_class</field>
    <field
            name="inherit_id"
            ref="ssi_master_data_mixin.mixin_master_data_view_search"
        />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//search" position="inside">
                <field name="school_id" />
                <field name="grade_id" />
                <group expand="0" string="Group By">
                    <filter
                            name="group_by_school_id"
                            string="School"
                            context="{'group_by': 'school_id'}"
                        />
                    <filter
                            name="group_by_grade_type_id"
                            string="Grade Type"
                            context="{'group_by': 'grade_type_id'}"
                        />
                    <filter
                            name="group_by_grade_id"
                            string="Grade"
                            context="{'group_by': 'grade_id'}"
                        />
                </group>
            </xpath>
        </data>
    </field>
</record>

<record id="school_grade_class_view_tree" model="ir.ui.view">
    <field name="name">school_grade_class -tree</field>
    <field name="model">school_grade_class</field>
    <field name="inherit_id" ref="ssi_master_data_mixin.mixin_master_data_view_tree" />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='name']" position="after">
                <field name="school_id" />
                <field name="grade_type_id" />
                <field name="grade_id" />
            </xpath>
        </data>
    </field>
</record>

<record id="school_grade_class_view_form" model="ir.ui.view">
    <field name="name">school_grade_class - form</field>
    <field name="model">school_grade_class</field>
    <field name="inherit_id" ref="ssi_master_data_mixin.mixin_master_data_view_form" />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='active']" position="after">
                <field name="school_id" />
                <field name="grade_type_id" />
                <field name="grade_id" domain="[('type_id', '=', grade_type_id)]" />
            </xpath>
        </data>
    </field>
</record>

<record id="school_grade_class_action" model="ir.actions.act_window">
    <field name="name">School Grade Classes</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">school_grade_class</field>
    <field name="view_mode">tree,form</field>
</record>

<menuitem
        id="school_grade_class_menu"
        name="Grade Classes"
        parent="menu_grade_configuration"
        action="school_grade_class_action"
        groups="school_grade_class_group"
        sequence="140"
    />

</odoo>

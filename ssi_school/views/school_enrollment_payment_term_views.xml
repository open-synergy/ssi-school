<odoo>

<record id="school_enrollment_payment_term_view_search" model="ir.ui.view">
    <field name="name">school_enrollment_payment_term - search</field>
    <field name="model">school_enrollment_payment_term</field>
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <search>
            <field name="name" />
            <field name="enrollment_id" />
            <field name="partner_id" />
            <filter
                    name="uninvoiced"
                    string="Uninvoiced"
                    domain="[('state','=','uninvoiced')]"
                />
            <filter
                    name="invoiced"
                    string="Invoiced"
                    domain="[('state','=','invoiced')]"
                />
        </search>
    </field>
</record>

<record id="school_enrollment_payment_term_view_tree" model="ir.ui.view">
    <field name="name">school_enrollment_payment_term - tree</field>
    <field name="model">school_enrollment_payment_term</field>
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <tree create="false" edit="false" delete="false">
            <field name="sequence" invisible="1" />
            <field name="enrollment_id" />
            <field name="partner_id" />
            <field name="name" />
            <field name="date_invoice" />
            <field name="date_due" />
            <field name="currency_id" invisible="1" />
            <field name="amount_untaxed" />
            <field name="amount_tax" />
            <field name="amount_total" />
            <field name="invoice_id" />
            <field name="state" />
            <button
                    name="action_create_invoice"
                    title="Create Invoice"
                    type="object"
                    icon="fa-cogs"
                    states="uninvoiced"
                />
            <button
                    name="action_delete_invoice"
                    title="Delete Invoice"
                    type="object"
                    icon="fa-eraser"
                    states="invoiced"
                />
            <button
                    name="action_disconnect_invoice"
                    title="Disconnect Invoice"
                    type="object"
                    icon="fa-unlink"
                    states="invoiced"
                />
            <button
                    name="action_mark_as_manual"
                    title="Mark as Manual"
                    type="object"
                    icon="fa-square-o"
                    states="uninvoiced"
                />
            <button
                    name="action_unmark_as_manual"
                    title="Unmark as Manual"
                    type="object"
                    icon="fa-check-square-o"
                    states="manual"
                />
        </tree>
    </field>
</record>

<record id="school_enrollment_payment_term_view_form_embedded" model="ir.ui.view">
    <field name="name">school_enrollment_payment_term - form (embedded)</field>
    <field name="model">school_enrollment_payment_term</field>
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <form>
            <header />
            <sheet>
                <group name="term_header" colspan="4" col="2">
                    <group name="term_header_left" colspan="1" col="2">
                        <field name="partner_id" />
                    </group>
                    <group name="term_header_right" colspan="1" col="2">
                        <field name="name" />
                        <field name="sequence" />
                        <field name="date_invoice" />
                        <field name="date_due" />
                        <field name="currency_id" invisible="1" />
                    </group>
                </group>
                <notebook>
                    <page name="term_detail" string="Detail">
                        <field name="detail_ids" colspan="2" nolabel="1">
                            <tree>
                                <field name="sequence" widget="handle" />
                                <field name="product_id" />
                                <field name="name" />
                                <field name="account_id" />
                                <field name="currency_id" invisible="1" />
                                <field name="pricelist_id" invisible="1" />
                                <field name="price_unit" />
                                <field name="uom_quantity" string="Quantity" />
                                <field name="uom_id" />
                                <field name="price_subtotal" />
                                <field name="tax_ids" widget="many2many_tags" />
                                <field name="price_tax" />
                                <field name="price_total" />
                            </tree>
                            <form>
                                <header />
                                <sheet>
                                    <group name="detail_group" colspan="4" col="2">
                                        <group name="detail_left" colspan="1" col="2">
                                            <field name="product_id" />
                                            <field name="name" />
                                            <field name="usage_id" />
                                            <field name="account_id" />
                                            <field name="analytic_account_id" />
                                        </group>
                                        <group name="detail_right" colspan="1" col="2">
                                            <label
                                                    for="uom_quantity"
                                                    string="Quantity"
                                                />
                                            <div>
                                                <field
                                                        name="uom_quantity"
                                                        class="oe_inline"
                                                    />
                                                <field
                                                        name="uom_id"
                                                        attrs="{'required':[('product_id','!=',False)]}"
                                                        class="oe_inline"
                                                    />
                                            </div>
                                            <field
                                                    name="currency_id"
                                                    invisible="1"
                                                    force_save="1"
                                                />
                                            <field
                                                    name="pricelist_id"
                                                    invisible="1"
                                                    force_save="1"
                                                />
                                            <field name="price_unit" />
                                            <field name="price_subtotal" />
                                            <field
                                                    name="tax_ids"
                                                    widget="many2many_tags"
                                                />
                                            <field name="price_tax" />
                                            <field name="price_total" />
                                        </group>
                                    </group>
                                </sheet>
                            </form>
                        </field>
                    </page>
                </notebook>
                <group name="term_footer" colspan="4" col="2">
                    <group name="term_footer_left" colspan="1" col="2">
                        <field name="amount_untaxed" />
                        <field name="amount_tax" />
                        <field name="amount_total" />
                    </group>
                </group>
            </sheet>
        </form>
    </field>
</record>


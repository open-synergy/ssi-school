<odoo>
<record id="school_student_view_search" model="ir.ui.view">
    <field name="name">school_student - search</field>
    <field name="model">school_student</field>
    <field
            name="inherit_id"
            ref="ssi_master_data_mixin.mixin_master_data_view_search"
        />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//search" position="inside">
                <field name="contact_id" />
                <field name="school_id" />
                <field name="current_grade_id" />
                <field name="grade_class_id" />
                <separator />
                <filter
                        name="filter_draft"
                        string="Registered"
                        domain="[('state', '=', 'draft')]"
                    />
                <filter
                        name="filter_enrol"
                        string="Enrolled"
                        domain="[('state', '=', 'enrol')]"
                    />
                <filter
                        name="filter_graduate"
                        string="Graduated"
                        domain="[('state', '=', 'graduate')]"
                    />
                <filter
                        name="filter_dropped"
                        string="Dropped"
                        domain="[('state', '=', 'dropped')]"
                    />
                <filter
                        name="filter_transferred"
                        string="Transferred"
                        domain="[('state', '=', 'transferred')]"
                    />
                <group expand="0" string="Group By">
                    <filter
                            name="group_by_school_id"
                            string="School"
                            context="{'group_by': 'school_id'}"
                        />
                    <filter
                            name="group_by_current_grade_type_id"
                            string="Grade Type"
                            context="{'group_by': 'current_grade_type_id'}"
                        />
                    <filter
                            name="group_by_current_grade_id"
                            string="Current Grade"
                            context="{'group_by': 'current_grade_id'}"
                        />
                    <filter
                            name="group_by_grade_class_id"
                            string="Class"
                            context="{'group_by': 'grade_class_id'}"
                        />
                    <filter
                            name="group_by_state"
                            string="Status"
                            context="{'group_by': 'state'}"
                        />
                </group>
            </xpath>
        </data>
    </field>
</record>

<record id="school_student_view_tree" model="ir.ui.view">
    <field name="name">school_student -tree</field>
    <field name="model">school_student</field>
    <field name="inherit_id" ref="ssi_master_data_mixin.mixin_master_data_view_tree" />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='name']" position="after">
                <field name="contact_id" />
                <field name="school_id" />
                <field name="current_grade_id" />
                <field name="current_grade_type_id" />
                <field name="grade_class_id" />
                <field name="state" />
            </xpath>
        </data>
    </field>
</record>

<record id="school_student_view_form" model="ir.ui.view">
    <field name="name">school_student - form</field>
    <field name="model">school_student</field>
    <field name="inherit_id" ref="ssi_master_data_mixin.mixin_master_data_view_form" />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//widget[@name='web_ribbon']" position="after">
                <field name="image_1920" widget='image' class="oe_avatar" />
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="contact_id" />

            </xpath>
            <xpath expr="//field[@name='code']" position="after">
                <field name="state" widget="badge" />
            </xpath>
            <xpath expr="//page[1]" position="before">
                <page name="address" string="Contact &amp; Address">
                    <group name="address_1" colspan="4" col="2">
                        <group name="address_1_1" colspan="1" col="2">
                            <span class="o_form_label o_td_label" name="address_name">
                                <b>Address</b>
                            </span>
                            <div class="o_address_format">
                                <field
                                        name="street"
                                        placeholder="Street..."
                                        class="o_address_street"
                                    />
                                <field
                                        name="street2"
                                        placeholder="Street 2..."
                                        class="o_address_street"
                                    />
                                <field
                                        name='city_id'
                                        placeholder="City ..."
                                        class="o_address_city"
                                        context="{'default_country_id': country_id,
                                            'default_zipcode': zip,
                                            'default_state_id': state_id}"
                                        domain="[('country_id', '=', country_id)]"
                                    />
                                <field
                                        name="state_id"
                                        class="o_address_state"
                                        placeholder="State"
                                        context="{'country_id': country_id, 'default_country_id': country_id, 'zip': zip}"
                                    />
                                <field
                                        name="zip"
                                        placeholder="ZIP"
                                        class="o_address_zip"
                                    />
                                <field
                                        name="country_id"
                                        placeholder="Country"
                                        class="o_address_country"
                                        options='{"no_open": True, "no_create": True}'
                                    />
                            </div>
                        </group>
                        <group name="address_1_2" colspan="1" col="2">
                            <field name="phone" widget="phone" />
                            <field name="mobile" widget="phone" />
                            <field name="email" widget="email" />
                        </group>
                    </group>
                </page>
                <page name="enrollment" string="Enrollments">
                    <group name="enrollment_1" colspan="4" col="2">
                        <group name="enrollment_1_1" colspan="1" col="2">
                            <field name="school_id" />
                            <field name="initial_grade_type_id" />
                            <field
                                    name="initial_grade_id"
                                    domain="[('type_id', '=', initial_grade_type_id)]"
                                />

                        </group>
                        <group name="enrollment_1_2" colspan="1" col="2">
                            <field name="current_grade_id" />
                            <field name="current_grade_type_id" />
                            <field name="next_grade_id" />
                        </group>
                    </group>
                    <group name="enrollment_2" colspan="4" col="2">
                        <field name="active_enrollment_id" />
                    </group>
                    <field name="enrollment_ids" />
                </page>
                <page name="family" string="Family">
                    <group name="family_1" colspan="4" col="2">
                        <field name="father_id" />
                        <field name="mother_id" />
                        <field name="guardian_id" />
                    </group>
                </page>
            </xpath>
        </data>
    </field>
</record>

<record id="school_student_action" model="ir.actions.act_window">
    <field name="name">Students</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">school_student</field>
    <field name="view_mode">tree,form</field>
</record>

<menuitem
        id="school_student_menu"
        name="Students"
        parent="menu_school_root"
        action="school_student_action"
        groups="school_student_group"
        sequence="110"
    />

</odoo>

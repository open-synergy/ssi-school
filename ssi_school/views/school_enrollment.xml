<odoo>
    <record id="school_enrollment_view_search" model="ir.ui.view">
        <field name="name">school_enrollment - search</field>
        <field name="model">school_enrollment</field>
    <field
            name="inherit_id"
            ref="ssi_transaction_mixin.mixin_transaction_view_search"
        />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//search" position="inside">
                <field name="student_id" />
                <field name="school_id" />
                <field name="academic_year_id" />
                <field name="academic_term_id" />
                <field name="grade_id" />
                <field name="grade_class_id" />
                <group expand="0" string="Group By">
                    <filter
                            name="group_by_school_id"
                            string="School"
                            context="{'group_by': 'school_id'}"
                        />
                    <filter
                            name="group_by_academic_year_id"
                            string="Academic Year"
                            context="{'group_by': 'academic_year_id'}"
                        />
                    <filter
                            name="group_by_academic_term_id"
                            string="Academic Term"
                            context="{'group_by': 'academic_term_id'}"
                        />
                    <filter
                            name="group_by_grade_type_id"
                            string="Grade Type"
                            context="{'group_by': 'grade_type_id'}"
                        />
                    <filter
                            name="group_by_grade_id"
                            string="Grade"
                            context="{'group_by': 'grade_id'}"
                        />
                    <filter
                            name="group_by_grade_class_id"
                            string="Class"
                            context="{'group_by': 'grade_class_id'}"
                        />
                </group>
            </xpath>
        </data>
    </field>
</record>

<record id="school_enrollment_view_tree" model="ir.ui.view">
    <field name="name">school_enrollment - tree</field>
    <field name="model">school_enrollment</field>
    <field name="mode">primary</field>
    <field name="inherit_id" ref="ssi_transaction_mixin.mixin_transaction_view_tree" />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="date" />
                <field name="student_id" />
                <field name="academic_year_id" />
                <field name="academic_term_id" />
                <field name="school_id" />
                <field name="grade_type_id" />
                <field name="grade_id" />
                <field name="grade_class_id" />
            </xpath>
        </data>
    </field>
</record>

<record id="school_enrollment_view_form" model="ir.ui.view">
    <field name="name">school_enrollment - form</field>
    <field name="model">school_enrollment</field>
    <field name="mode">primary</field>
    <field name="inherit_id" ref="ssi_transaction_mixin.mixin_transaction_view_form" />
    <field name="arch" type="xml">
        <data>
            <xpath expr="//header/field[@name='state']" position="before">
                <button
                        name="action_set_result_to_passed"
                        type="object"
                        string="Pass"
                        confirm="Set result to Pass?"
                        attrs="{'invisible':[('pass_ok','=',False)]}"
                        groups="ssi_school.school_enrollment_user_group"
                    />
                <button
                        name="action_set_result_to_failed"
                        type="object"
                        string="Fail"
                        confirm="Set result to Fail?"
                        attrs="{'invisible':[('fail_ok','=',False)]}"
                        groups="ssi_school.school_enrollment_user_group"
                    />
                <button
                        name="action_set_result_to_drop_out"
                        type="object"
                        string="Drop Out"
                        confirm="Set result to Drop Out?"
                        attrs="{'invisible':[('drop_out_ok','=',False)]}"
                        groups="ssi_school.school_enrollment_user_group"
                    />
                <button
                        name="action_set_result_to_graduate"
                        type="object"
                        string="Graduate"
                        confirm="Set result to Graduate?"
                        attrs="{'invisible':[('graduate_ok','=',False)]}"
                        groups="ssi_school.school_enrollment_user_group"
                    />
            </xpath>
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="academic_year_id" />
                <field
                        name="academic_term_id"
                        domain="[('year_id','=',academic_year_id),('enrollment_state','=','open')]"
                    />
                <field name="last_term" />
                <field name="school_id" />
                <field name="grade_type_id" />
                <field name="grade_id" domain="[('type_id','=',grade_type_id)]" />
                <field
                        name="allowed_student_ids"
                        widget="many2many_tags"
                        invisible="1"
                    />
                <field name="student_id" domain="[('id','=',allowed_student_ids)]" />
                <field
                        name="grade_class_id"
                        domain="[('grade_id','=',grade_id),('school_id','=',school_id)]"
                    />
            </xpath>
            <xpath expr="//group[@name='header_right']" position="inside">
                <field name="date" />
                <field name="currency_id" />
                <field
                        name="allowed_pricelist_ids"
                        widget="many2many_tags"
                        invisible="1"
                    />
                <field
                        name="pricelist_id"
                        domain="[('id','in',allowed_pricelist_ids)]"
                    />
            </xpath>
            <xpath expr="//page[1]" position="before">
                <page
                        name="academic_year_result"
                        attrs="{'invisible':[('last_term','=',False)]}"
                        string="Academic Year Result"
                    >
                    <group name="academic_year_result_group" colspan="4" col="2">
                        <field name="academic_year_result" />
                        <field name="promote_to_grade_id" />
                    </group>
                </page>
                <page name="billing" string="Billing">
                    <group name="billing_template" colspan="4" col="2">
                        <group name="billing_template_left" colspan="1" col="2">
                            <field
                                    name="payment_template_id"
                                    domain="[('academic_term_id','in',[academic_term_id,False]),('school_id','in',[school_id,False]),('grade_id','in',[grade_id,False])]"
                                />
                        </group>
                        <group name="billing_template_right" colspan="1" col="2">
                            <button
                                    name="action_compute_payment"
                                    type="object"
                                    string="Compute Payment"
                                    confirm="This will replace existing payment terms. Continue?"
                                    attrs="{'invisible':['|',('payment_template_id','=',False),('state','!=','draft')]}"
                                    class="btn-primary"
                                />
                        </group>
                    </group>
                    <field
                            name="payment_term_ids"
                            colspan="4"
                            nolabel="1"
                            context="{'form_view_ref': 'ssi_school.school_enrollment_payment_term_view_form_embedded'}"
                        >
                        <tree create="true" edit="true" delete="true">
                            <field name="sequence" widget="handle" />
                            <field name="name" />
                            <field name="date_invoice" />
                            <field name="date_due" />
                            <field name="currency_id" invisible="1" />
                            <field name="amount_untaxed" />
                            <field name="amount_tax" />
                            <field name="amount_total" />
                            <field name="invoice_id" />
                            <field name="state" />
                            <button
                                    name="action_create_invoice"
                                    title="Create Invoice"
                                    type="object"
                                    icon="fa-cogs"
                                    states="uninvoiced"
                                />
                            <button
                                    name="action_delete_invoice"
                                    title="Delete Invoice"
                                    type="object"
                                    icon="fa-eraser"
                                    states="invoiced"
                                />
                            <button
                                    name="action_disconnect_invoice"
                                    title="Disconnect Invoice"
                                    type="object"
                                    icon="fa-unlink"
                                    states="invoiced"
                                />
                            <button
                                    name="action_mark_as_manual"
                                    title="Mark as Manual"
                                    type="object"
                                    icon="fa-square-o"
                                    states="uninvoiced"
                                />
                            <button
                                    name="action_unmark_as_manual"
                                    title="Unmark as Manual"
                                    type="object"
                                    icon="fa-check-square-o"
                                    states="manual"
                                />
                        </tree>
                    </field>
                </page>
                <page name="accounting" string="Accounting">
                    <group name="accounting_group" colspan="4" col="2">
                        <field name="receivable_journal_id" />
                        <field name="receivable_account_id" />
                    </group>
                </page>
                <page name="payment_summary" string="Payment Summary">
                    <field name="product_summary_ids" nolabel="1" colspan="4">
                        <tree create="false" edit="false" delete="false">
                            <field name="product_id" />
                            <field name="uom_quantity" />
                            <field name="currency_id" invisible="1" />
                            <field name="amount_untaxed" />
                            <field name="amount_tax" />
                            <field name="amount_total" />
                        </tree>
                    </field>
                </page>
            </xpath>
            <xpath expr="//group[@name='policy_2']" position="inside">
                <field name="pass_ok" />
                <field name="fail_ok" />
                <field name="drop_out_ok" />
                <field name="graduate_ok" />
            </xpath>
        </data>
    </field>
</record>

<record id="school_enrollment_action" model="ir.actions.act_window">
    <field name="name">Enrollments</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">school_enrollment</field>
    <field name="view_mode">tree,form</field>
</record>

<menuitem
        id="school_enrollment_menu"
        name="Enrollments"
        parent="ssi_school.menu_school_root"
        action="school_enrollment_action"
        groups="school_enrollment_viewer_group"
        sequence="150"
    />

</odoo>

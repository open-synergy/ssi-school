<odoo>
<record id="policy_template_school_admission_form" model="policy.template">
    <field name="name">Standard</field>
    <field name="model_id" ref="model_school_admission_form" />
    <field
            name="state_field_id"
            search="[('model_id.model','=','school_admission_form'),('name','=','state')]"
        />
    <field name="sequence" eval="100" />
    <field name="python_code">result=True</field>
</record>

<!-- Confirm -->
<record
        id="policy_template_school_admission_form_confirm"
        model="policy.template_detail"
    >
    <field name="template_id" ref="policy_template_school_admission_form" />
    <field
            name="field_id"
            search="[('model_id.model','=','school_admission_form'),('name','=','confirm_ok')]"
        />
    <field name="restrict_state" eval="1" />
    <field
            name="state_ids"
            search="[('field_id.model_id.model','=','school_admission_form'),('value','=','draft')]"
        />
    <field name="restrict_user" eval="1" />
    <field name="computation_method">use_group</field>
    <field name="group_ids" eval="[(6,0,[ref('school_admission_form_user_group')])]" />
    <field name="restrict_additional" eval="0" />
</record>

<!-- Approve -->
<record
        id="policy_template_school_admission_form_approve"
        model="policy.template_detail"
    >
    <field name="template_id" ref="policy_template_school_admission_form" />
    <field
            name="field_id"
            search="[('model_id.model','=','school_admission_form'),('name','=','approve_ok')]"
        />
    <field name="restrict_state" eval="1" />
    <field
            name="state_ids"
            search="[('field_id.model_id.model','=','school_admission_form'),('value','=','confirm')]"
        />
    <field name="restrict_user" eval="0" />
    <field name="restrict_additional" eval="1" />
    <field name="additional_python_code">result = False
if env.user.id in document.active_approver_user_ids.ids:
    result = True</field>
</record>


<odoo>
<record id="school_admission_period_view_search" model="ir.ui.view">
    <field name="name">school_admission_period - search</field>
    <field name="model">school_admission_period</field>
    <field
            name="inherit_id"
            ref="ssi_master_data_mixin.mixin_master_data_view_search"
        />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data />
    </field>
</record>

<record id="school_admission_period_view_tree" model="ir.ui.view">
    <field name="name">school_admission_period -tree</field>
    <field name="model">school_admission_period</field>
    <field name="inherit_id" ref="ssi_master_data_mixin.mixin_master_data_view_tree" />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//field[@name='name']" position="after">
                <field name="term_id" />
                <field name="date_start" />
                <field name="date_end" />
                <field name="state" />
            </xpath>
        </data>
    </field>
</record>

<record id="school_admission_period_view_form" model="ir.ui.view">
    <field name="name">school_admission_period - form</field>
    <field name="model">school_admission_period</field>
    <field name="inherit_id" ref="ssi_master_data_mixin.mixin_master_data_view_form" />
    <field name="mode">primary</field>
    <field name="arch" type="xml">
        <data>
            <xpath expr="//header" position="inside">
                <button
                        name="action_open"
                        string="Start"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible':[('state','!=','draft')]}"
                    />
                <button
                        name="action_done"
                        string="Done"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible':[('state','!=','open')]}"
                    />
                <button
                        name="action_restart"
                        string="Restart"
                        type="object"
                        class="oe_highlight"
                        attrs="{'invisible':[('state','=','draft')]}"
                    />
                <field name="state" widget="statusbar" />
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="term_id" />
                <field name="date_start" />
                <field name="date_end" />
            </xpath>
        </data>
    </field>
</record>

<record id="school_admission_period_action" model="ir.actions.act_window">
    <field name="name">Admission Periods</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">school_admission_period</field>
    <field name="view_mode">tree,form</field>
</record>

<menuitem
        id="school_admission_period_menu"
        name="Admission Periods"
        parent="ssi_school.menu_period_configuration"
        action="school_admission_period_action"
        groups="school_admission_period_group"
        sequence="130"
    />

</odoo>

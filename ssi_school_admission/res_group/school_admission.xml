<odoo>
<!-- Workflow -->
<record id="school_admission_viewer_group" model="res.groups">
    <field name="name">Viewer</field>
    <field name="category_id" ref="school_admission_workflow_module_category" />
</record>

<record id="school_admission_user_group" model="res.groups">
    <field name="name">User</field>
    <field name="category_id" ref="school_admission_workflow_module_category" />
    <field name="implied_ids" eval="[(4, ref('school_admission_viewer_group'))]" />
</record>

<record id="school_admission_validator_group" model="res.groups">
    <field name="name">Validator</field>
    <field name="category_id" ref="school_admission_workflow_module_category" />
    <field name="implied_ids" eval="[(4, ref('school_admission_user_group'))]" />
    <field
            name="users"
            eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"
        />
</record>

<!-- Data Ownership -->
<record id="school_admission_company_group" model="res.groups">
    <field name="name">Company</field>
    <field name="category_id" ref="school_admission_data_ownership_module_category" />
</record>

<record id="school_admission_company_child_group" model="res.groups">
    <field name="name">Company and All Child Companies</field>
    <field name="category_id" ref="school_admission_data_ownership_module_category" />
    <field name="implied_ids" eval="[(4, ref('school_admission_company_group'))]" />
</record>

<record id="school_admission_all_group" model="res.groups">
    <field name="name">All</field>
    <field name="category_id" ref="school_admission_data_ownership_module_category" />
    <field
            name="implied_ids"
            eval="[(4, ref('school_admission_company_child_group'))]"
        />
</record>

<!-- Configurator -->
<record id="school_admission_payment_template_group" model="res.groups">
    <field name="name">Admission Payment Template</field>
    <field name="category_id" ref="ssi_school.school_configurator_module_category" />
    <field
            name="users"
            eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"
        />
</record>
</odoo>
